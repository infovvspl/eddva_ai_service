		{
			"name": "1. Auth - Login Flow",
			"description": "OTP-based authentication. Run these in order.\n\nIn dev mode, OTP is always 123456.\nThe access_token is auto-saved for all subsequent requests.",
			"item": [
				{
					"name": "Step 1: Send OTP",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('OTP sent successfully', function () {",
									"    pm.response.to.have.status(200);",
									"    var json = pm.response.json();",
									"    pm.expect(json.message).to.include('OTP');",
									"});",
									"console.log('OTP sent. In dev mode, use 123456');"
								]
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"phoneNumber\": \"{{phone_number}}\"\n}"
						},
						"url": { "raw": "{{nestjs_url}}/auth/otp/send", "host": ["{{nestjs_url}}"], "path": ["auth", "otp", "send"] }
					},
					"response": [
						{
							"name": "200 OTP Sent",
							"status": "OK",
							"code": 200,
							"body": "{\n  \"message\": \"OTP sent successfully\",\n  \"expiresIn\": 300\n}"
						}
					]
				},
				{
					"name": "Step 2: Verify OTP & Get Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('OTP verified & token received', function () {",
									"    pm.response.to.have.status(200);",
									"    var json = pm.response.json();",
									"    pm.expect(json.accessToken).to.be.a('string');",
									"    ",
									"    // Auto-save tokens to collection variables",
									"    pm.collectionVariables.set('access_token', json.accessToken);",
									"    pm.collectionVariables.set('refresh_token', json.refreshToken);",
									"    pm.collectionVariables.set('user_id', json.user.id);",
									"    ",
									"    console.log('Token saved! User ID: ' + json.user.id);",
									"    console.log('Is new user: ' + json.isNewUser);",
									"    console.log('Onboarding required: ' + json.onboardingRequired);",
									"});"
								]
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"phoneNumber\": \"{{phone_number}}\",\n  \"otp\": \"{{otp_code}}\"\n}"
						},
						"url": { "raw": "{{nestjs_url}}/auth/otp/verify", "host": ["{{nestjs_url}}"], "path": ["auth", "otp", "verify"] }
					},
					"response": [
						{
							"name": "200 Token Received",
							"status": "OK",
							"code": 200,
							"body": "{\n  \"accessToken\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"refreshToken\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"user\": {\n    \"id\": \"uuid\",\n    \"phoneNumber\": \"+919876543210\",\n    \"fullName\": \"Student\",\n    \"role\": \"student\",\n    \"status\": \"active\"\n  },\n  \"isNewUser\": true,\n  \"onboardingRequired\": true\n}"
						}
					]
				},
				{
					"name": "Step 3: Get My Profile",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Profile retrieved', function () {",
									"    pm.response.to.have.status(200);",
									"    var json = pm.response.json();",
									"    console.log('User: ' + json.user.fullName + ' (' + json.user.role + ')');",
									"    if (json.student) {",
									"        pm.collectionVariables.set('student_id', json.student.id);",
									"        console.log('Student ID saved: ' + json.student.id);",
									"    }",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{access_token}}" }
						],
						"url": { "raw": "{{nestjs_url}}/auth/me", "host": ["{{nestjs_url}}"], "path": ["auth", "me"] }
					},
					"response": [
						{
							"name": "200 Profile",
							"status": "OK",
							"code": 200,
							"body": "{\n  \"user\": {\n    \"id\": \"uuid\",\n    \"phoneNumber\": \"+919876543210\",\n    \"fullName\": \"Student Name\",\n    \"role\": \"student\",\n    \"status\": \"active\"\n  },\n  \"student\": {\n    \"id\": \"uuid\",\n    \"examTarget\": \"jee\",\n    \"class\": \"12\"\n  }\n}"
						}
					]
				},
				{
					"name": "Refresh Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Token refreshed', function () {",
									"    pm.response.to.have.status(200);",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('access_token', json.accessToken);",
									"    pm.collectionVariables.set('refresh_token', json.refreshToken);",
									"    console.log('New access token saved');",
									"});"
								]
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}"
						},
						"url": { "raw": "{{nestjs_url}}/auth/refresh", "host": ["{{nestjs_url}}"], "path": ["auth", "refresh"] }
					},
					"response": [
						{
							"name": "200 Refreshed",
							"status": "OK",
							"code": 200,
							"body": "{\n  \"accessToken\": \"eyJ...\",\n  \"refreshToken\": \"eyJ...\"\n}"
						}
					]
				}
			]
		},
		{
			"name": "2. Onboarding (New Users)",
			"description": "Run this after login if isNewUser=true or onboardingRequired=true.\nSets up the student profile required for AI services.",
			"item": [
				{
					"name": "Complete Student Onboarding",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Onboarding completed', function () {",
									"    pm.response.to.have.status(200);",
									"    var json = pm.response.json();",
									"    if (json.student) {",
									"        pm.collectionVariables.set('student_id', json.student.id);",
									"        console.log('Student profile created: ' + json.student.id);",
									"    }",
									"    console.log('Next step: ' + (json.nextStep || 'ready'));",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{access_token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"examTarget\": \"jee\",\n  \"class\": \"12\",\n  \"examYear\": \"2027\",\n  \"targetCollege\": \"IIT Delhi - Computer Science\",\n  \"dailyStudyHours\": 5,\n  \"language\": \"en\",\n  \"city\": \"Delhi\",\n  \"state\": \"Delhi\"\n}"
						},
						"url": { "raw": "{{nestjs_url}}/auth/onboard", "host": ["{{nestjs_url}}"], "path": ["auth", "onboard"] }
					},
					"response": [
						{
							"name": "200 Onboarded",
							"status": "OK",
							"code": 200,
							"body": "{\n  \"student\": {\n    \"id\": \"uuid\",\n    \"userId\": \"uuid\",\n    \"examTarget\": \"jee\",\n    \"class\": \"12\",\n    \"examYear\": \"2027\",\n    \"dailyStudyHours\": 5,\n    \"language\": \"en\"\n  },\n  \"message\": \"Profile created. Proceed to diagnostic test.\",\n  \"nextStep\": \"diagnostic_test\"\n}"
						}
					]
				}
			]
		},
		{
			"name": "3. AI - Doubt Resolution (E2E)",
			"description": "End-to-end doubt resolution flow:\nPostman → NestJS (/doubts) → Django (/doubt/resolve) → Groq LLM → Response\n\nRequires: JWT token from Auth flow",
			"item": [
				{
					"name": "Create Doubt (AI Resolves)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Doubt created and AI resolved', function () {",
									"    pm.response.to.have.status(201);",
									"    var json = pm.response.json();",
									"    ",
									"    pm.collectionVariables.set('doubt_id', json.id);",
									"    ",
									"    // Verify AI fields are populated",
									"    pm.expect(json.status).to.eql('ai_resolved');",
									"    pm.expect(json.aiExplanation).to.be.a('string');",
									"    pm.expect(json.aiExplanation.length).to.be.above(10);",
									"    ",
									"    console.log('Doubt ID: ' + json.id);",
									"    console.log('Status: ' + json.status);",
									"    console.log('AI Explanation (preview): ' + json.aiExplanation.substring(0, 200) + '...');",
									"    console.log('AI Concept Links: ' + JSON.stringify(json.aiConceptLinks));",
									"});",
									"",
									"pm.test('Response time under 30s', function () {",
									"    pm.expect(pm.response.responseTime).to.be.below(30000);",
									"    console.log('Response time: ' + pm.response.responseTime + 'ms');",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{access_token}}" },
							{ "key": "Content-Type", "value": "application/json" }
