						"url": {"raw": "{{base_url}}/auth/onboard", "host": ["{{base_url}}"], "path": ["auth","onboard"]}
					},
					"response": [{"name":"200 OK","status":"OK","code":200,"body":"{\n  \"student\": { \"id\": \"uuid\", \"examTarget\": \"jee\" },\n  \"message\": \"Profile created.\"\n}"}]
				},
				{
					"name": "Verify: Get My Profile",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Profile OK', function() { pm.response.to.have.status(200); var j=pm.response.json(); console.log('Role: '+j.user.role); });"
					]}}],
