		{
			"name": "1. Auth - Login (Run First!)",
			"description": "Run these in order. Token auto-saves for all subsequent requests.",
			"item": [
				{
					"name": "Step 1: Send OTP",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('OTP sent', function() { pm.response.to.have.status(200); });",
						"console.log('Dev OTP: 123456');"
					]}}],
					"request": {
						"auth": {"type":"noauth"},
						"method": "POST",
						"header": [{"key":"Content-Type","value":"application/json"}],
						"body": {"mode":"raw","raw":"{\n  \"phoneNumber\": \"{{phone_number}}\"\n}"},
						"url": {"raw": "{{base_url}}/auth/otp/send", "host": ["{{base_url}}"], "path": ["auth","otp","send"]}
					},
					"response": [{"name":"200 OK","status":"OK","code":200,"body":"{\n  \"message\": \"OTP sent successfully\",\n  \"expiresIn\": 300\n}"}]
				},
				{
					"name": "Step 2: Verify OTP → Get JWT",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Token received', function() {",
						"    pm.response.to.have.status(200);",
						"    var j = pm.response.json();",
						"    pm.collectionVariables.set('access_token', j.accessToken);",
						"    pm.collectionVariables.set('refresh_token', j.refreshToken);",
						"    pm.collectionVariables.set('user_id', j.user.id);",
						"    console.log('JWT saved! User: ' + j.user.id);",
						"    console.log('New user: ' + j.isNewUser + ', Onboarding: ' + j.onboardingRequired);",
						"});"
					]}}],
					"request": {
						"auth": {"type":"noauth"},
						"method": "POST",
						"header": [{"key":"Content-Type","value":"application/json"}],
						"body": {"mode":"raw","raw":"{\n  \"phoneNumber\": \"{{phone_number}}\",\n  \"otp\": \"{{otp_code}}\"\n}"},
						"url": {"raw": "{{base_url}}/auth/otp/verify", "host": ["{{base_url}}"], "path": ["auth","otp","verify"]}
					},
					"response": [{"name":"200 Token","status":"OK","code":200,"body":"{\n  \"accessToken\": \"eyJ...\",\n  \"refreshToken\": \"eyJ...\",\n  \"user\": { \"id\": \"uuid\", \"role\": \"student\" },\n  \"isNewUser\": true\n}"}]
				},
				{
					"name": "Step 3: Onboard Student (if new)",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
