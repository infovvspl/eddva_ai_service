	},
	"variable": [
		{ "key": "base_url", "value": "http://localhost:3000/api/v1", "type": "string" },
		{ "key": "django_url", "value": "http://localhost:8000", "type": "string" },
		{ "key": "phone_number", "value": "+919876543210", "type": "string" },
		{ "key": "otp_code", "value": "123456", "type": "string" },
		{ "key": "access_token", "value": "", "type": "string" },
		{ "key": "refresh_token", "value": "", "type": "string" },
		{ "key": "user_id", "value": "", "type": "string" },
		{ "key": "doubt_id", "value": "", "type": "string" },
		{ "key": "tutor_session_id", "value": "", "type": "string" }
