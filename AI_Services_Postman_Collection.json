		{
			"name": "Auth Tests",
			"description": "Authentication validation tests",
			"item": [
				{
					"name": "Auth - No Key (Expect 401)",
					"request": {
						"auth": { "type": "noauth" },
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/content/suggest/?topic=Physics",
							"host": ["{{base_url}}"],
							"path": ["content", "suggest", ""],
							"query": [{ "key": "topic", "value": "Physics" }]
						}
					},
					"response": [
						{
							"name": "401 Unauthorized",
							"originalRequest": {
								"method": "GET",
								"url": { "raw": "{{base_url}}/content/suggest/?topic=Physics", "host": ["{{base_url}}"], "path": ["content", "suggest", ""] }
							},
							"status": "Unauthorized",
							"code": 401,
							"body": "{\n  \"error\": \"Missing API key. Include X-API-Key header or Authorization: Bearer <key>\"\n}"
						}
					]
				},
